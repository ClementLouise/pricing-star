---
import Eyebrow from './Eyebrow.astro';
import { copy } from '../content/copy';

const { persona } = copy;
---

<section class="bg-bg py-section-sm md:py-section">
  <div class="max-w-container mx-auto px-8 flex flex-col items-center text-center">

    <div class="reveal">
      <Eyebrow text={persona.eyebrow} centered />
    </div>

    <blockquote class="max-w-[800px] reveal reveal-delay-1">
      <p class="font-serif font-light italic text-[32px] md:text-[36px] text-text-primary leading-[1.3]">
        "{persona.quote}"
      </p>
      <footer class="mt-8">
        <cite class="font-mono text-[11px] uppercase tracking-mono-label text-text-tertiary not-italic">
          {persona.attribution}
        </cite>
      </footer>
    </blockquote>

  </div>
</section>
