---
import Eyebrow from './Eyebrow.astro';
import { copy } from '../content/copy';

const { hero } = copy;
---

<section class="min-h-screen flex items-center justify-center pt-14">
  <div class="max-w-container mx-auto px-8 py-32">
    <div class="max-w-copy-wide">
      <!-- Eyebrow -->
      <div class="reveal">
        <Eyebrow text={hero.eyebrow} />
      </div>

      <!-- Title -->
      <h1 class="font-serif font-light text-display-lg md:text-display-xl text-text-primary mb-8 reveal reveal-delay-1">
        {hero.titleLine1}<br />
        <em>{hero.titleLine2}</em>
      </h1>

      <!-- Subtext -->
      <p class="text-xl md:text-[21px] text-text-secondary leading-relaxed max-w-[620px] mb-10 reveal reveal-delay-2">
        {hero.subtext}
      </p>

      <!-- Caption -->
      <p class="font-mono text-[11px] text-text-tertiary tracking-mono-label reveal reveal-delay-3">
        {hero.caption}
      </p>
    </div>
  </div>
</section>

<style>
  /* Hero fade-in on load (not scroll) */
  section {
    animation: hero-fade 0.8s ease-out both;
  }
  @keyframes hero-fade {
    from { opacity: 0; }
    to { opacity: 1; }
  }

  /* Override reveal for hero — animate on load, not scroll */
  section .reveal {
    opacity: 0;
    transform: translateY(20px);
    animation: reveal-up 0.7s ease-out forwards;
  }
  section .reveal-delay-1 { animation-delay: 0.15s; }
  section .reveal-delay-2 { animation-delay: 0.3s; }
  section .reveal-delay-3 { animation-delay: 0.45s; }

  @keyframes reveal-up {
    to { opacity: 1; transform: translateY(0); }
  }

  @media (prefers-reduced-motion: reduce) {
    section, section .reveal {
      animation: none;
      opacity: 1;
      transform: none;
    }
  }
</style>
