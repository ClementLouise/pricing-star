# Pricing Star — Frontend ENV vars (Vite build-time)
# Copy to .env.local for local development. Never commit .env.local.
# These are injected at BUILD TIME by Vite — set them in Railway dashboard
# under the frontend service environment variables before each deploy.

VITE_AUTH0_DOMAIN=your-tenant.auth0.com
VITE_AUTH0_CLIENT_ID=your-spa-client-id
VITE_AUTH0_AUDIENCE=https://api.pricingstar.io
VITE_API_BASE_URL=https://your-backend.up.railway.app/api
