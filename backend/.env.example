# Pricing Star — Backend ENV vars
# Copy to .env for local development. Never commit .env.

# --- Required: app crashes at startup if missing ---

DATABASE_URL=postgresql+asyncpg://user:pass@host:5432/pricingstar
AUTH0_DOMAIN=your-tenant.auth0.com
AUTH0_CLIENT_ID=your-m2m-client-id
AUTH0_CLIENT_SECRET=your-m2m-client-secret
WEBHOOK_SECRET=generate-with-openssl-rand-hex-32

# --- Optional with defaults ---

ENVIRONMENT=production
REDIS_URL=redis://localhost:6379/0
AUTH0_AUDIENCE=https://api.pricingstar.io
ALLOWED_ORIGINS=https://your-frontend.up.railway.app
SENTRY_DSN=
TRIAL_MAX_ASSETS=5
TRIAL_MAX_SCENARIOS_PER_ASSET=3
TRIAL_MAX_USERS=3
